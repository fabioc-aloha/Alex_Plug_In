{
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/session-start.js",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/stop.js",
                        "timeout": 10
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/pre-tool-use.js",
                        "timeout": 2
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/post-tool-use.js",
                        "timeout": 2
                    }
                ]
            }
        ]
    }
}
