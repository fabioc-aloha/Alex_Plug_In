{
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/session-start.cjs",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/stop.cjs",
                        "timeout": 10
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/pre-tool-use.cjs",
                        "timeout": 2
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/post-tool-use.cjs",
                        "timeout": 2
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/prompt-safety-gate.cjs",
                        "timeout": 2
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node .github/muscles/hooks/subagent-context.cjs",
                        "timeout": 3
                    }
                ]
            }
        ]
    }
}
